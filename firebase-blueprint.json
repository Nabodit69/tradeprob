{
  "entities": {
    "Strategy": {
      "title": "Strategy",
      "description": "A trading strategy configuration",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "targetWinRate": { "type": "number" },
        "description": { "type": "string" },
        "isArchived": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "name", "targetWinRate", "createdAt"]
    },
    "Trade": {
      "title": "Trade",
      "description": "A single trade log entry",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "strategyId": { "type": "string" },
        "entryTime": { "type": "string", "format": "date-time" },
        "exitTime": { "type": "string", "format": "date-time" },
        "dayOfWeek": { "type": "string" },
        "session": { "type": "string", "enum": ["London", "New York", "Asia"] },
        "setup": { "type": "string" },
        "result": { "type": "string", "enum": ["Win", "Loss"] },
        "pips": { "type": "number" },
        "slPips": { "type": "number" },
        "tpPips": { "type": "number" },
        "notes": { "type": "string" },
        "screenshotUrl": { "type": "string" },
        "durationMinutes": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "strategyId", "entryTime", "exitTime", "result", "pips", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Root user profiles"
    },
    "/strategies/{strategyId}": {
      "schema": "Strategy",
      "description": "Trading strategies"
    },
    "/trades/{tradeId}": {
      "schema": "Trade",
      "description": "Individual trade records"
    }
  }
}
